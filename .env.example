# Cosmania DEX -- Environment Variables

# Required: Mistral AI for agent conversations
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Cosmania health server URL (where /dex/agents lives)
COSMANIA_URL=http://localhost:8080

# DEX server port
DEX_PORT=3333

# Autonomous backend group chat loop (optional)
DEX_AUTONOMY_ENABLED=0
DEX_AUTONOMY_INTERVAL_MS=45000
DEX_AUTONOMY_ROUNDS=1
DEX_AUTONOMY_SESSION_ID=dex-autonomy
# Optional comma-separated allowlist of agents for autonomous turns.
# DEX_AUTONOMY_AGENTS=sentinel,dreamer,coder,observer

# Group-session autonomy (enabled by default)
DEX_GROUP_AUTONOMY_ENABLED=1
DEX_GROUP_AUTONOMY_MIN_MS=18000
DEX_GROUP_AUTONOMY_MAX_MS=70000
DEX_GROUP_SESSION_IDLE_TTL_MS=2400000

# Discord bot (Phase 2)
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Honcho -- persistent agent memory
HONCHO_API_KEY=
HONCHO_WORKSPACE=cosmania-dex

# W&B Weave tracing (auto-enabled when key is set)
WANDB_API_KEY=

# ElevenLabs voice synthesis (Phase 3)
ELEVENLABS_API_KEY=
