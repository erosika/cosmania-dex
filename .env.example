# Cosmania DEX -- Environment Variables

# Required: Mistral AI for agent conversations
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Cosmania health server URL (where /dex/agents lives)
COSMANIA_URL=http://localhost:8080

# DEX server port
DEX_PORT=3333

# Discord bot (Phase 2)
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Honcho -- persistent agent memory
HONCHO_API_KEY=
HONCHO_WORKSPACE=cosmania-dex

# W&B Weave tracing (all Mistral calls logged)
WANDB_API_KEY=

# ElevenLabs voice synthesis (Phase 3)
ELEVENLABS_API_KEY=
